# ─────────────────────────────────────────────────────────────
# DolarPix — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# ─────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────
NODE_ENV="development"           # development | production
PORT=3001                        # Porta do backend Express
APP_URL="http://localhost:3000"  # URL do frontend (usada pelo CORS)

# ─── Autenticação JWT ──────────────────────────────────────────
# Gere uma string segura:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="troque-por-uma-string-aleatoria-e-longa"

# ─── Admin ─────────────────────────────────────────────────────
# Senha de acesso ao painel admin em /admin
# Acesse: http://localhost:3000/admin
ADMIN_SECRET="troque-por-uma-senha-forte-de-admin"

# ─── Gemini AI ────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ─── Stellar ──────────────────────────────────────────────────
# Escolha a rede: "testnet" para desenvolvimento, "mainnet" para produção.
#
# TESTNET
#   - Friendbot financia contas novas automaticamente (sem custo)
#   - Sem XLM real, sem risco financeiro
#   - Rode "npm run stellar:setup" para gerar uma conta de teste
#   - Explorer: https://stellar.expert/explorer/testnet
#
# MAINNET
#   - Transações reais com XLM/USDC/USDT
#   - Contas novas precisam de pelo menos 1 XLM para ativar
#   - Explorer: https://stellar.expert/explorer/public
#
STELLAR_NETWORK="testnet"        # testnet | mainnet

# Conta operacional do servidor (opcional no testnet).
# Rode "npm run stellar:setup" para gerar e cole os valores aqui.
STELLAR_PUBLIC_KEY=""
STELLAR_SECRET_KEY=""

# ─── Asset Issuers ────────────────────────────────────────────
# Emissor do USDC na rede selecionada.
#
# Testnet  (Centre/Circle): GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet  (Circle):        GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
#
ASSET_ISSUER="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"
